'Declaracao de variaveis
Dim dolar As double 
Dim euro As double
Dim valor As double

'Entrada de dados
print "Digite o valor que deseja converter para dolar e euro: "
Input Valor

'Calculos de conversao
dolar = valor / 5.00
euro = valor / 5.40

'Saida de dados
print "Valor em reais: ";valor
print "Valor convertido em dolares: ";dolar
print "Valor convertido em euros: ";euro

Sleep
